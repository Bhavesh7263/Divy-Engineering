window.uploadProduct = async function(){
  const name = document.getElementById('prod-name').value.trim();
  const cat  = document.getElementById('prod-cat').value;
  const grade= document.getElementById('prod-grade').value.trim();
  const size = document.getElementById('prod-size').value.trim();
  const desc = document.getElementById('prod-desc').value.trim();
  const alertEl = document.getElementById('upload-alert');

  if(!name||!cat){ alertEl.innerHTML='<div class="alert alert-error"><i class="ti ti-alert-circle"></i> Product name and category are required.</div>'; return; }
  if(window.__selectedFiles.length===0){ alertEl.innerHTML='<div class="alert alert-error"><i class="ti ti-alert-circle"></i> Please select at least one image.</div>'; return; }

  alertEl.innerHTML='<div class="alert alert-info"><i class="ti ti-loader"></i> Uploading images to Cloudinary...</div>';
  const progressWrap = document.getElementById('progress-wrap');
  const progressFill = document.getElementById('progress-fill');
  const progressLabel = document.getElementById('progress-label');
  progressWrap.style.display='block';

  try {
    const imageUrls = [];
    for(let i=0; i<window.__selectedFiles.length; i++){
      progressLabel.textContent = `Uploading image ${i+1} of ${window.__selectedFiles.length}...`;
      const url = await uploadToCloudinary(window.__selectedFiles[i], pct => {
        const overall = ((i / window.__selectedFiles.length) + (pct/100/window.__selectedFiles.length)) * 100;
        progressFill.style.width = overall+'%';
      });
      imageUrls.push(url);
    }
    progressFill.style.width='100%';
    progressLabel.textContent='Saving to database...';

    await addDoc(collection(db,'products'),{
      name, category:cat, grade, size, description:desc,
      imageUrl: imageUrls[0], images: imageUrls,
      createdAt: serverTimestamp()
    });

    alertEl.innerHTML='<div class="alert alert-success"><i class="ti ti-check"></i> Product uploaded successfully! It is now live on your website.</div>';
    progressWrap.style.display='none';
    showToast('Product uploaded successfully!');
    clearForm();
    loadProducts();
  } catch(e){
    alertEl.innerHTML=`<div class="alert alert-error"><i class="ti ti-alert-circle"></i> Error: ${e.message}</div>`;
    progressWrap.style.display='none';
  }
};

