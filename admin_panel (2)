function renderManageTable(items){
  const tbody = document.getElementById('products-tbody');
  if(!items||items.length===0){ tbody.innerHTML='<tr><td colspan="7"><div class="empty-state"><i class="ti ti-packages"></i><p>No products yet.</p></div></td></tr>'; return; }
  tbody.innerHTML = items.map(p=>`
    <tr>
      <td>${p.imageUrl?`<img src="${p.imageUrl}" alt="${p.name}">`:'<i class="ti ti-photo" style="font-size:24px;color:var(--border);"></i>'}</td>
      <td><strong>${p.name||'—'}</strong></td>
      <td><span class="badge badge-orange">${p.category||'—'}</span></td>
      <td>${p.grade||'—'}</td>
      <td style="font-size:13px;color:var(--text2);">${p.size||'—'}</td>
      <td style="font-size:12px;color:var(--text2);">${p.createdAt?.toDate ? p.createdAt.toDate().toLocaleDateString('en-IN') : '—'}</td>
      <td><button class="btn btn-red btn-sm" onclick="deleteProduct('${p.id}')"><i class="ti ti-trash"></i> Delete</button></td>
    </tr>`).join('');
}

function renderDashRecent(items){
  const el = document.getElementById('dash-recent-products');
  if(!items||items.length===0){ el.innerHTML='<div class="empty-state"><i class="ti ti-packages"></i><p>No products yet.</p></div>'; return; }
  el.innerHTML=`<table class="prod-table"><thead><tr><th>Image</th><th>Name</th><th>Category</th><th>Grade</th></tr></thead><tbody>${items.map(p=>`<tr><td>${p.imageUrl?`<img src="${p.imageUrl}" alt="${p.name}">`:'—'}</td><td>${p.name||'—'}</td><td><span class="badge badge-orange">${p.category||'—'}</span></td><td>${p.grade||'—'}</td></tr>`).join('')}</tbody></table>`;
}

