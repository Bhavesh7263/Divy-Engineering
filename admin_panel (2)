<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Panel — Divy Engineering</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700;900&family=Barlow+Condensed:wght@700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --orange:#E8650A;--orange2:#FF7A1A;--orange-light:#FFF0E6;
  --dark:#1A0A00;--text:#2D1A00;--text2:#6B4C2A;--border:#E8D5C0;
  --white:#FFFFFF;--bg:#F7F3EE;--bg2:#F0EBE4;
  --red:#DC2626;--green:#16A34A;--blue:#2563EB;
}
body{background:var(--bg);color:var(--text);font-family:'Barlow',sans-serif;font-size:15px;}

/* LOGIN */
.login-wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#FFF5EE,#FFE0C0);}
.login-box{background:var(--white);border:1px solid var(--border);padding:3rem;width:100%;max-width:420px;border-radius:8px;box-shadow:0 8px 40px rgba(232,101,10,0.12);}
.login-logo{text-align:center;margin-bottom:2rem;}
.login-logo .logo-icon{width:56px;height:56px;background:var(--orange);clip-path:polygon(20% 0%,80% 0%,100% 20%,100% 80%,80% 100%,20% 100%,0% 80%,0% 20%);display:flex;align-items:center;justify-content:center;font-weight:900;font-size:24px;color:#fff;font-family:'Barlow Condensed',sans-serif;margin:0 auto 1rem;}
.login-logo h2{font-family:'Barlow Condensed',sans-serif;font-size:22px;font-weight:900;color:var(--dark);}
.login-logo p{font-size:13px;color:var(--text2);margin-top:4px;}
.login-form h3{font-family:'Barlow Condensed',sans-serif;font-size:20px;font-weight:700;color:var(--dark);margin-bottom:1.5rem;text-align:center;text-transform:uppercase;}
.form-group{margin-bottom:1.25rem;}
.form-group label{display:block;font-size:12px;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;}
.form-group input{width:100%;background:var(--bg);border:1.5px solid var(--border);color:var(--text);padding:11px 14px;font-family:inherit;font-size:14px;outline:none;transition:border-color 0.2s;border-radius:4px;}
.form-group input:focus{border-color:var(--orange);background:#fff;}
.btn-login{width:100%;background:var(--orange);color:#fff;padding:13px;font-weight:700;font-size:15px;text-transform:uppercase;border:none;cursor:pointer;border-radius:4px;transition:background 0.2s;display:flex;align-items:center;justify-content:center;gap:8px;}
.btn-login:hover{background:var(--orange2);}
.login-error{background:#FEE2E2;border:1px solid #FECACA;color:var(--red);padding:10px 14px;border-radius:4px;font-size:13px;margin-bottom:1rem;display:none;}

/* ADMIN LAYOUT */
.admin-wrap{display:none;min-height:100vh;}
.admin-sidebar{width:240px;background:var(--dark);position:fixed;top:0;left:0;height:100vh;overflow-y:auto;z-index:10;}
.sidebar-logo{padding:1.5rem 1.25rem;border-bottom:1px solid rgba(255,255,255,0.08);}
.sidebar-logo .logo-icon{width:36px;height:36px;background:var(--orange);clip-path:polygon(20% 0%,80% 0%,100% 20%,100% 80%,80% 100%,20% 100%,0% 80%,0% 20%);display:inline-flex;align-items:center;justify-content:center;font-weight:900;font-size:16px;color:#fff;font-family:'Barlow Condensed',sans-serif;vertical-align:middle;margin-right:8px;}
.sidebar-logo span{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:16px;color:#fff;line-height:1.2;display:inline-block;vertical-align:middle;}
.sidebar-logo small{display:block;font-size:10px;color:rgba(255,255,255,0.4);letter-spacing:2px;text-transform:uppercase;margin-top:4px;margin-left:44px;}
.sidebar-nav{padding:1rem 0;}
.sidebar-section{padding:0.5rem 1.25rem;font-size:10px;font-weight:700;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:2px;margin-top:0.75rem;}
.sidebar-link{display:flex;align-items:center;gap:10px;padding:11px 1.25rem;color:rgba(255,255,255,0.6);font-size:14px;font-weight:500;cursor:pointer;transition:all 0.2s;text-decoration:none;}
.sidebar-link:hover{background:rgba(255,255,255,0.06);color:#fff;}
.sidebar-link.active{background:var(--orange);color:#fff;}
.sidebar-link i{font-size:18px;}
.sidebar-bottom{position:absolute;bottom:0;left:0;right:0;padding:1rem 1.25rem;border-top:1px solid rgba(255,255,255,0.08);}
.btn-logout{width:100%;background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.6);padding:10px;font-weight:600;font-size:13px;text-transform:uppercase;border:1px solid rgba(255,255,255,0.1);cursor:pointer;border-radius:4px;display:flex;align-items:center;justify-content:center;gap:6px;transition:all 0.2s;}
.btn-logout:hover{background:var(--red);color:#fff;border-color:var(--red);}

.admin-main{margin-left:240px;min-height:100vh;}
.admin-topbar{background:var(--white);border-bottom:1px solid var(--border);padding:0 2rem;height:60px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:5;}
.topbar-title{font-family:'Barlow Condensed',sans-serif;font-size:22px;font-weight:700;color:var(--dark);text-transform:uppercase;}
.topbar-user{display:flex;align-items:center;gap:10px;font-size:14px;color:var(--text2);}
.user-avatar{width:36px;height:36px;background:var(--orange);border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;color:#fff;font-size:15px;}
.admin-content{padding:2rem;}

/* PANELS */
.panel{display:none;}
.panel.active{display:block;}

/* CARDS */
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem;margin-bottom:2rem;}
.stat-card{background:var(--white);border:1px solid var(--border);padding:1.5rem;border-radius:6px;border-left:4px solid var(--orange);}
.stat-card .num{font-family:'Barlow Condensed',sans-serif;font-size:40px;font-weight:900;color:var(--orange);line-height:1;}
.stat-card .lbl{font-size:12px;color:var(--text2);text-transform:uppercase;letter-spacing:1px;margin-top:4px;font-weight:600;}

/* CARD */
.card{background:var(--white);border:1px solid var(--border);border-radius:6px;overflow:hidden;margin-bottom:1.5rem;}
.card-header{padding:1.25rem 1.5rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.card-header h3{font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:700;text-transform:uppercase;color:var(--dark);}
.card-body{padding:1.5rem;}

/* FORM */
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
.fg{margin-bottom:1.25rem;}
.fg label{display:block;font-size:12px;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;}
.fg input,.fg select,.fg textarea{width:100%;background:var(--bg);border:1.5px solid var(--border);color:var(--text);padding:10px 14px;font-family:inherit;font-size:14px;outline:none;transition:border-color 0.2s;border-radius:4px;}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--orange);background:#fff;}
.fg textarea{min-height:80px;resize:vertical;}
.fg.full{grid-column:1/-1;}

/* UPLOAD AREA */
.upload-area{border:2px dashed var(--border);background:var(--bg);padding:2.5rem;text-align:center;cursor:pointer;transition:all 0.2s;border-radius:6px;position:relative;}
.upload-area:hover,.upload-area.drag{border-color:var(--orange);background:var(--orange-light);}
.upload-area input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;}
.upload-area i{font-size:40px;color:var(--orange);margin-bottom:1rem;display:block;}
.upload-area p{color:var(--text2);font-size:14px;}
.upload-area span{color:var(--orange);font-weight:600;}
.preview-wrap{display:flex;flex-wrap:wrap;gap:1rem;margin-top:1rem;}
.preview-item{position:relative;width:100px;height:100px;border-radius:4px;overflow:hidden;border:2px solid var(--border);}
.preview-item img{width:100%;height:100%;object-fit:cover;}
.preview-item .remove-img{position:absolute;top:4px;right:4px;background:var(--red);color:#fff;border:none;width:20px;height:20px;border-radius:50%;cursor:pointer;font-size:11px;display:flex;align-items:center;justify-content:center;}

/* PROGRESS */
.progress-wrap{margin-top:1rem;display:none;}
.progress-bar{height:6px;background:var(--border);border-radius:3px;overflow:hidden;}
.progress-fill{height:100%;background:var(--orange);width:0%;transition:width 0.3s;border-radius:3px;}
.progress-label{font-size:12px;color:var(--text2);margin-top:6px;}

/* BUTTONS */
.btn{padding:10px 22px;font-weight:700;font-size:14px;text-transform:uppercase;border:none;cursor:pointer;border-radius:4px;display:inline-flex;align-items:center;gap:6px;transition:all 0.2s;letter-spacing:0.5px;}
.btn-orange{background:var(--orange);color:#fff;} .btn-orange:hover{background:var(--orange2);}
.btn-red{background:var(--red);color:#fff;}
.btn-green{background:var(--green);color:#fff;}
.btn-outline{background:transparent;color:var(--orange);border:1.5px solid var(--orange);} .btn-outline:hover{background:var(--orange);color:#fff;}
.btn-sm{padding:6px 14px;font-size:12px;}

/* PRODUCTS TABLE */
.prod-table{width:100%;border-collapse:collapse;}
.prod-table th{background:var(--orange);color:#fff;padding:10px 14px;text-align:left;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;}
.prod-table td{padding:10px 14px;border-bottom:1px solid var(--border);font-size:14px;color:var(--text);}
.prod-table tr:hover td{background:var(--orange-light);}
.prod-table td img{width:48px;height:48px;object-fit:cover;border-radius:4px;border:1px solid var(--border);}
.badge{display:inline-block;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;}
.badge-orange{background:var(--orange-light);color:var(--orange);}
.badge-green{background:#DCFCE7;color:var(--green);}

/* ALERTS */
.alert{padding:12px 16px;border-radius:4px;font-size:14px;margin-bottom:1rem;display:flex;align-items:center;gap:8px;font-weight:500;}
.alert-success{background:#DCFCE7;border:1px solid #BBF7D0;color:var(--green);}
.alert-error{background:#FEE2E2;border:1px solid #FECACA;color:var(--red);}
.alert-info{background:var(--orange-light);border:1px solid rgba(232,101,10,0.2);color:var(--orange);}
.toast-admin{position:fixed;bottom:2rem;right:2rem;background:var(--orange);color:#fff;padding:14px 22px;font-weight:700;font-size:14px;z-index:999;transform:translateY(100px);transition:transform 0.3s;border-radius:4px;box-shadow:0 4px 20px rgba(232,101,10,0.3);display:flex;align-items:center;gap:8px;}
.toast-admin.show{transform:translateY(0);}

/* EMPTY STATE */
.empty-state{text-align:center;padding:3rem;color:var(--text2);}
.empty-state i{font-size:48px;color:var(--border);margin-bottom:1rem;display:block;}

/* TABS */
.tabs{display:flex;gap:0;border-bottom:2px solid var(--border);margin-bottom:2rem;}
.tab{padding:10px 20px;font-weight:600;font-size:14px;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;color:var(--text2);text-transform:uppercase;letter-spacing:0.5px;transition:all 0.2s;}
.tab:hover{color:var(--orange);}
.tab.active{color:var(--orange);border-bottom-color:var(--orange);}

/* HERO IMAGE SECTION */
.hero-img-preview{width:100%;max-width:400px;aspect-ratio:16/9;background:var(--bg2);border:2px solid var(--border);border-radius:6px;overflow:hidden;margin-bottom:1rem;}
.hero-img-preview img{width:100%;height:100%;object-fit:cover;}
</style>
</head>
<body>

<!-- LOGIN -->
<div class="login-wrap" id="login-wrap">
  <div class="login-box">
    <div class="login-logo">
      <div class="logo-icon">D</div>
      <h2>Divy Engineering</h2>
      <p>Admin Panel — Secure Login</p>
    </div>
    <div class="login-error" id="login-error"><i class="ti ti-alert-circle"></i> <span id="login-error-msg">Invalid credentials</span></div>
    <div class="login-form">
      <h3>Sign In</h3>
      <div class="form-group">
        <label>Username</label>
        <input type="text" id="login-email" placeholder="Enter username">
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" id="login-password" placeholder="••••••••">
      </div>
      <button class="btn-login" onclick="doLogin()"><i class="ti ti-lock"></i> Sign In to Admin</button>
    </div>
  </div>
</div>

<!-- ADMIN -->
<div class="admin-wrap" id="admin-wrap">
  <!-- SIDEBAR -->
  <div class="admin-sidebar">
    <div class="sidebar-logo">
      <span class="logo-icon">D</span><span>Divy Engineering</span>
      <small>Engineering — Admin</small>
    </div>
    <nav class="sidebar-nav">
      <div class="sidebar-section">Main</div>
      <div class="sidebar-link active" onclick="showPanel('dashboard')"><i class="ti ti-dashboard"></i> Dashboard</div>
      <div class="sidebar-section">Content</div>
      <div class="sidebar-link" onclick="showPanel('upload')"><i class="ti ti-cloud-upload"></i> Upload Products</div>
      <div class="sidebar-link" onclick="showPanel('manage')"><i class="ti ti-packages"></i> Manage Products</div>
      <div class="sidebar-link" onclick="showPanel('hero')"><i class="ti ti-photo"></i> Hero / Banner Images</div>
      <div class="sidebar-section">Website</div>
      <div class="sidebar-link" onclick="showPanel('settings')"><i class="ti ti-settings"></i> Site Settings</div>
      <div class="sidebar-link" onclick="window.open('radhe_krishna_website.html','_blank')"><i class="ti ti-external-link"></i> View Website</div>
    </nav>
    <div class="sidebar-bottom">
      <button class="btn-logout" onclick="doLogout()"><i class="ti ti-logout"></i> Sign Out</button>
    </div>
  </div>

  <!-- MAIN -->
  <div class="admin-main">
    <div class="admin-topbar">
      <div class="topbar-title" id="topbar-title">Dashboard</div>
      <div class="topbar-user">
        <div class="user-avatar" id="user-initial">A</div>
        <div>
          <div style="font-weight:600;color:var(--dark);font-size:14px;" id="user-name">Admin</div>
          <div style="font-size:12px;color:var(--text2);">Administrator</div>
        </div>
      </div>
    </div>
    <div class="admin-content">

      <!-- DASHBOARD -->
      <div class="panel active" id="panel-dashboard">
        <div id="dash-alert" class="alert alert-info" style="display:none;"></div>
        <div class="stats-row">
          <div class="stat-card"><div class="num" id="stat-total">0</div><div class="lbl">Total Products</div></div>
          <div class="stat-card"><div class="num" id="stat-cats">8</div><div class="lbl">Categories</div></div>
          <div class="stat-card"><div class="num">100+</div><div class="lbl">Countries Served</div></div>
          <div class="stat-card"><div class="num">25+</div><div class="lbl">Years Experience</div></div>
        </div>
        <div class="card">
          <div class="card-header"><h3>Recent Products</h3><button class="btn btn-orange btn-sm" onclick="showPanel('upload')"><i class="ti ti-plus"></i> Add Product</button></div>
          <div class="card-body">
            <div id="dash-recent-products"><div class="empty-state"><i class="ti ti-packages"></i><p>No products yet. Upload your first product!</p></div></div>
          </div>
        </div>
        <div class="card">
          <div class="card-header"><h3>Quick Actions</h3></div>
          <div class="card-body" style="display:flex;gap:1rem;flex-wrap:wrap;">
            <button class="btn btn-orange" onclick="showPanel('upload')"><i class="ti ti-cloud-upload"></i> Upload New Product</button>
            <button class="btn btn-outline" onclick="showPanel('manage')"><i class="ti ti-packages"></i> Manage Products</button>
            <button class="btn btn-outline" onclick="showPanel('hero')"><i class="ti ti-photo"></i> Update Hero Image</button>
            <button class="btn btn-outline" onclick="window.open('radhe_krishna_website.html','_blank')"><i class="ti ti-external-link"></i> View Website</button>
          </div>
        </div>
      </div>

      <!-- UPLOAD PRODUCTS -->
      <div class="panel" id="panel-upload">
        <div class="card">
          <div class="card-header"><h3><i class="ti ti-cloud-upload" style="color:var(--orange);"></i> Upload New Product</h3></div>
          <div class="card-body">
            <div id="upload-alert"></div>
            <div class="form-grid">
              <div class="fg"><label>Product Name *</label><input type="text" id="prod-name" placeholder="e.g. SS 316L Seamless Tube"></div>
              <div class="fg"><label>Category *</label>
                <select id="prod-cat">
                  <option value="">Select Category</option>
                  <option>SS Tubes</option><option>SS Pipes</option><option>SS Fittings</option>
                  <option>SS Flanges</option><option>SS Valves</option><option>Sheet & Plates</option>
                  <option>Bars & Rods</option><option>Fasteners</option>
                </select>
              </div>
              <div class="fg"><label>Grade / Material</label><input type="text" id="prod-grade" placeholder="e.g. 304, 316L, 2205"></div>
              <div class="fg"><label>Size / Specification</label><input type="text" id="prod-size" placeholder="e.g. 1/2 inch to 24 inch NB"></div>
              <div class="fg full"><label>Description</label><textarea id="prod-desc" placeholder="Brief product description..."></textarea></div>
              <div class="fg full">
                <label>Product Images (select multiple)</label>
                <div class="upload-area" id="upload-area">
                  <input type="file" id="img-input" accept="image/*" multiple onchange="handleFiles(this.files)">
                  <i class="ti ti-photo-up"></i>
                  <p>Drag & drop images here or <span>click to browse</span></p>
                  <p style="font-size:12px;margin-top:6px;color:var(--text2);">Supports JPG, PNG, WEBP — max 10MB each</p>
                </div>
                <div class="preview-wrap" id="preview-wrap"></div>
                <div class="progress-wrap" id="progress-wrap">
                  <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
                  <div class="progress-label" id="progress-label">Uploading...</div>
                </div>
              </div>
            </div>
            <div style="display:flex;gap:1rem;margin-top:1rem;">
              <button class="btn btn-orange" onclick="uploadProduct()"><i class="ti ti-cloud-upload"></i> Upload to Website</button>
              <button class="btn btn-outline" onclick="clearForm()"><i class="ti ti-x"></i> Clear Form</button>
            </div>
          </div>
        </div>
      </div>

      <!-- MANAGE PRODUCTS -->
      <div class="panel" id="panel-manage">
        <div class="card">
          <div class="card-header">
            <h3><i class="ti ti-packages" style="color:var(--orange);"></i> All Products</h3>
            <div style="display:flex;gap:0.75rem;align-items:center;">
              <input type="text" id="search-prod" placeholder="Search products..." onkeyup="filterProducts()" style="padding:8px 14px;border:1.5px solid var(--border);border-radius:4px;font-family:inherit;font-size:13px;outline:none;width:200px;">
              <button class="btn btn-orange btn-sm" onclick="showPanel('upload')"><i class="ti ti-plus"></i> Add New</button>
            </div>
          </div>
          <div class="card-body" style="padding:0;">
            <div id="manage-alert" style="padding:1rem 1.5rem;"></div>
            <div style="overflow-x:auto;">
              <table class="prod-table">
                <thead><tr><th>Image</th><th>Name</th><th>Category</th><th>Grade</th><th>Size</th><th>Date</th><th>Actions</th></tr></thead>
                <tbody id="products-tbody"><tr><td colspan="7"><div class="empty-state"><i class="ti ti-packages"></i><p>No products yet.</p></div></td></tr></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <!-- HERO IMAGES -->
      <div class="panel" id="panel-hero">
        <!-- INFO BOX -->
        <div class="card">
          <div class="card-header">
            <h3><i class="ti ti-slideshow" style="color:var(--orange);"></i> Hero Slideshow Images</h3>
            <span style="font-size:13px;color:var(--text2);">These images appear on the right side of the Home page — fading every 3 seconds</span>
          </div>
          <div class="card-body">
            <div id="hero-alert"></div>

            <!-- HOW IT WORKS -->
            <div style="background:var(--orange-light);border:1px solid rgba(232,101,10,0.2);padding:1rem 1.5rem;border-radius:6px;margin-bottom:1.5rem;display:flex;align-items:center;gap:12px;">
              <i class="ti ti-info-circle" style="color:var(--orange);font-size:22px;flex-shrink:0;"></i>
              <p style="font-size:13px;color:var(--text2);line-height:1.6;"><strong style="color:var(--dark);">How it works:</strong> Upload 2–6 images below. They will automatically appear in the hero slideshow on your website, fading every 3 seconds. You can also delete any image anytime.</p>
            </div>

            <!-- CURRENT SLIDESHOW PREVIEW -->
            <div style="margin-bottom:2rem;">
              <div style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text2);margin-bottom:1rem;">Current Slideshow Images</div>
              <div id="current-slide-images" style="display:flex;flex-wrap:wrap;gap:1rem;">
                <div style="color:var(--text2);font-size:13px;padding:1rem;"><i class="ti ti-loader" style="color:var(--orange);"></i> Loading...</div>
              </div>
            </div>

            <!-- UPLOAD NEW IMAGES -->
            <div style="border-top:1px solid var(--border);padding-top:1.5rem;">
              <div style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text2);margin-bottom:1rem;">Upload New Slideshow Images (Max 6 total)</div>
              <div class="upload-area" id="hero-upload-area">
                <input type="file" id="hero-multi-input" accept="image/*" multiple onchange="handleHeroMultiFiles(this.files)">
                <i class="ti ti-photo-up"></i>
                <p>Drag & drop images here or <span>click to browse</span></p>
                <p style="font-size:12px;margin-top:6px;color:var(--text2);">Select 1–6 images • JPG, PNG, WEBP • Max 10MB each</p>
              </div>

              <!-- PREVIEW SELECTED -->
              <div id="hero-preview-wrap" class="preview-wrap" style="margin-top:1rem;"></div>

              <!-- PROGRESS -->
              <div class="progress-wrap" id="hero-progress-wrap" style="margin-top:1rem;">
                <div class="progress-bar"><div class="progress-fill" id="hero-progress-fill"></div></div>
